# ── NVIDIA NIM / OpenAI-compatible endpoint ───────────────────────────────────
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_API_KEY=""     # your NVIDIA API key
MODEL_NAME=z-ai/glm-5.1

# ── Thinking / reasoning tokens ───────────────────────────────────────────────
ENABLE_THINKING=true
SHOW_REASONING=true     # stream reasoning tokens to stderr so you can see progress

# ── Token limit ───────────────────────────────────────────────────────────────
# GLM with thinking enabled can burn 30K+ tokens on reasoning alone — keep this high.
# Lower only if the server drops connections mid-stream (incomplete chunked read).
MAX_TOKENS=16384

# ── Structured output ─────────────────────────────────────────────────────────
# Keep false for all non-OpenAI models (uses streaming + JSON extraction instead)
USE_STRUCTURED_OUTPUT=false
